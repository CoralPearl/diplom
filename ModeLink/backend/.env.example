# Server
PORT=3000
APP_BASE_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/modelink?schema=public

# JWT
JWT_SECRET=change_me_super_secret
JWT_EXPIRES_IN=7d

# Admin self-registration (recommended: keep disabled)
ALLOW_ADMIN_REGISTRATION=false
ADMIN_REGISTRATION_SECRET=

# OTP
OTP_TTL_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_ATTEMPTS=5

# SendGrid (optional - if empty, emails will be logged to console)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=no-reply@example.com

# AWS S3 (optional - if empty, files will be stored locally in /uploads)
S3_REGION=
S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# If your bucket is public, backend can return this URL:
S3_PUBLIC_BASE_URL=https://YOUR_BUCKET.s3.YOUR_REGION.amazonaws.com
