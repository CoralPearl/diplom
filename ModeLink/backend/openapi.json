{
  "openapi": "3.0.3",
  "info": {
    "title": "ModeLink API",
    "version": "0.1.0",
    "description": "Backend API для проекта ModeLink — цифровая экосистема управления моделями.\n\nАвторизация: Bearer JWT (header Authorization: Bearer <token>)."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local dev"
    }
  ],
  "tags": [
    {
      "name": "Health"
    },
    {
      "name": "Auth"
    },
    {
      "name": "ModelProfile"
    },
    {
      "name": "Models"
    },
    {
      "name": "Projects"
    },
    {
      "name": "Portfolio"
    },
    {
      "name": "Admin"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "details": {}
        },
        "required": [
          "error",
          "message"
        ]
      },
      "UserPublic": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "role": {
            "type": "string",
            "enum": [
              "model",
              "booker",
              "manager",
              "admin"
            ]
          },
          "isVerified": {
            "type": "boolean"
          }
        },
        "required": [
          "id",
          "email",
          "role",
          "isVerified"
        ]
      },
      "AuthTokenResponse": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          },
          "user": {
            "$ref": "#/components/schemas/UserPublic"
          }
        },
        "required": [
          "token",
          "user"
        ]
      },
      "OtpRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "purpose": {
            "type": "string",
            "enum": [
              "register"
            ],
            "default": "register"
          }
        },
        "required": [
          "email"
        ]
      },
      "OtpRequestResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "ok",
          "expiresAt"
        ]
      },
      "OtpVerify": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "purpose": {
            "type": "string",
            "enum": [
              "register"
            ],
            "default": "register"
          },
          "code": {
            "type": "string",
            "pattern": "^\\\\d{6}$"
          },
          "password": {
            "type": "string",
            "minLength": 8
          },
          "role": {
            "type": "string",
            "enum": [
              "model",
              "booker",
              "manager",
              "admin"
            ]
          },
          "adminRegistrationSecret": {
            "type": "string"
          }
        },
        "required": [
          "email",
          "code",
          "password",
          "role"
        ]
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "ModelProfile": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "userId": {
            "type": "string",
            "format": "uuid"
          },
          "fullName": {
            "type": "string"
          },
          "height": {
            "type": "integer",
            "nullable": true
          },
          "weight": {
            "type": "integer",
            "nullable": true
          },
          "bust": {
            "type": "integer",
            "nullable": true
          },
          "waist": {
            "type": "integer",
            "nullable": true
          },
          "hips": {
            "type": "integer",
            "nullable": true
          },
          "shoeSize": {
            "type": "number",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "userId",
          "fullName",
          "createdAt",
          "updatedAt"
        ]
      },
      "ModelProfileUpdate": {
        "type": "object",
        "properties": {
          "fullName": {
            "type": "string"
          },
          "height": {
            "type": "integer",
            "minimum": 50,
            "maximum": 250
          },
          "weight": {
            "type": "integer",
            "minimum": 20,
            "maximum": 250
          },
          "bust": {
            "type": "integer",
            "minimum": 40,
            "maximum": 200
          },
          "waist": {
            "type": "integer",
            "minimum": 40,
            "maximum": 200
          },
          "hips": {
            "type": "integer",
            "minimum": 40,
            "maximum": 250
          },
          "shoeSize": {
            "type": "number",
            "minimum": 20,
            "maximum": 60
          }
        }
      },
      "Project": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "modelId": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "format": "date-time"
          },
          "location": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "modelId",
          "title",
          "date",
          "location",
          "createdAt"
        ]
      },
      "ProjectCreate": {
        "type": "object",
        "properties": {
          "modelId": {
            "type": "string",
            "format": "uuid",
            "description": "Требуется для manager/admin. Для role=model игнорируется и подставляется текущая модель."
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "date": {
            "type": "string",
            "format": "date-time"
          },
          "location": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "title",
          "date",
          "location"
        ]
      },
      "ProjectUpdate": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          },
          "date": {
            "type": "string",
            "format": "date-time"
          },
          "location": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "PortfolioImage": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "modelId": {
            "type": "string",
            "format": "uuid"
          },
          "imageUrl": {
            "type": "string",
            "format": "uri"
          },
          "storageKey": {
            "type": "string",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "modelId",
          "imageUrl",
          "createdAt"
        ]
      },
      "ModelsListItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "userEmail": {
            "type": "string",
            "format": "email"
          },
          "fullName": {
            "type": "string"
          },
          "height": {
            "type": "integer",
            "nullable": true
          },
          "weight": {
            "type": "integer",
            "nullable": true
          },
          "bust": {
            "type": "integer",
            "nullable": true
          },
          "waist": {
            "type": "integer",
            "nullable": true
          },
          "hips": {
            "type": "integer",
            "nullable": true
          },
          "shoeSize": {
            "type": "number",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "portfolioCount": {
            "type": "integer"
          },
          "projectsCount": {
            "type": "integer"
          }
        },
        "required": [
          "id",
          "userEmail",
          "fullName",
          "createdAt",
          "updatedAt",
          "portfolioCount",
          "projectsCount"
        ]
      },
      "ModelDetails": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "userEmail": {
            "type": "string",
            "format": "email"
          },
          "fullName": {
            "type": "string"
          },
          "height": {
            "type": "integer",
            "nullable": true
          },
          "weight": {
            "type": "integer",
            "nullable": true
          },
          "bust": {
            "type": "integer",
            "nullable": true
          },
          "waist": {
            "type": "integer",
            "nullable": true
          },
          "hips": {
            "type": "integer",
            "nullable": true
          },
          "shoeSize": {
            "type": "number",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "portfolioImages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PortfolioImage"
            }
          },
          "projects": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Project"
            }
          }
        },
        "required": [
          "id",
          "userEmail",
          "fullName",
          "createdAt",
          "updatedAt",
          "portfolioImages",
          "projects"
        ]
      },
      "PagedModelsList": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ModelsListItem"
            }
          },
          "page": {
            "type": "integer",
            "example": 1
          },
          "limit": {
            "type": "integer",
            "example": 20
          },
          "total": {
            "type": "integer",
            "example": 100
          },
          "totalPages": {
            "type": "integer",
            "example": 5
          }
        },
        "required": [
          "items",
          "page",
          "limit",
          "total",
          "totalPages"
        ]
      },
      "AdminUserModelProfileSummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "fullName": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "fullName"
        ]
      },
      "AdminUser": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "role": {
            "type": "string",
            "enum": [
              "model",
              "booker",
              "manager",
              "admin"
            ]
          },
          "isVerified": {
            "type": "boolean"
          },
          "isBlocked": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "modelProfile": {
            "$ref": "#/components/schemas/AdminUserModelProfileSummary"
          }
        },
        "required": [
          "id",
          "email",
          "role",
          "isVerified",
          "isBlocked",
          "createdAt"
        ]
      },
      "PagedAdminUsers": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AdminUser"
            }
          },
          "page": {
            "type": "integer",
            "example": 1
          },
          "limit": {
            "type": "integer",
            "example": 20
          },
          "total": {
            "type": "integer",
            "example": 100
          },
          "totalPages": {
            "type": "integer",
            "example": 5
          }
        },
        "required": [
          "items",
          "page",
          "limit",
          "total",
          "totalPages"
        ]
      },
      "AdminUserPatchRequest": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "model",
              "booker",
              "manager",
              "admin"
            ]
          },
          "isBlocked": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "Health"
        ],
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "name": {
                      "type": "string"
                    },
                    "time": {
                      "type": "string",
                      "format": "date-time"
                    }
                  },
                  "required": [
                    "ok",
                    "name",
                    "time"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/auth/otp/request": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Запросить OTP на email (регистрация)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OtpRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OTP создан и отправлен (или залогирован в dev)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OtpRequestResponse"
                }
              }
            }
          },
          "409": {
            "description": "Пользователь уже существует",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Слишком часто запрашивают OTP (cooldown)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/auth/otp/verify": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Подтвердить OTP + создать пользователя + задать пароль + выбрать роль",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OtpVerify"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Успешно: возвращает JWT",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthTokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Неверный/истёкший OTP или ошибка валидации",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Запрещена саморегистрация admin",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Логин по email + пароль",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Успешно: возвращает JWT",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthTokenResponse"
                }
              }
            }
          },
          "401": {
            "description": "Неверные креды",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/auth/me": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Текущий пользователь",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "format": "uuid"
                    },
                    "email": {
                      "type": "string",
                      "format": "email"
                    },
                    "role": {
                      "type": "string",
                      "enum": [
                        "model",
                        "booker",
                        "manager",
                        "admin"
                      ]
                    },
                    "isVerified": {
                      "type": "boolean"
                    },
                    "modelProfile": {
                      "$ref": "#/components/schemas/ModelProfile"
                    }
                  },
                  "required": [
                    "id",
                    "email",
                    "role",
                    "isVerified"
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Нет/неверный JWT",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/model-profile/me": {
      "get": {
        "tags": [
          "ModelProfile"
        ],
        "summary": "Профиль модели (текущего пользователя)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ModelProfile"
                }
              }
            }
          },
          "401": {
            "description": "Нет/неверный JWT",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Роль не model",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/model-profile": {
      "put": {
        "tags": [
          "ModelProfile"
        ],
        "summary": "Обновить профиль модели",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ModelProfileUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ModelProfile"
                }
              }
            }
          },
          "401": {
            "description": "Нет/неверный JWT",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Роль не model",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/models": {
      "get": {
        "tags": [
          "Models"
        ],
        "summary": "List models (search/pagination/sorting)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PagedModelsList"
                }
              }
            }
          },
          "401": {
            "description": "Нет/неверный JWT",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Роль не booker/manager/admin",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "required": false
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1
            },
            "required": false
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            },
            "required": false
          },
          {
            "name": "sortBy",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "createdAt",
                "updatedAt",
                "fullName",
                "portfolioCount",
                "projectsCount"
              ]
            },
            "required": false
          },
          {
            "name": "order",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ]
            },
            "required": false
          }
        ]
      }
    },
    "/models/{id}": {
      "get": {
        "tags": [
          "Models"
        ],
        "summary": "Карточка модели (профиль + портфолио + проекты)",
        "security": [
          {
            "bearerAuth": []
          }
